; Far Horizon — Godot project configuration
; Engine: Godot 4.6 (Forward+). See ARCHITECTURE.md and docs/.

config_version=5

[application]

config/name="Far Horizon"
config/version="0.1.0"
run/main_scene="res://src/ui/shell/main.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

EventBus="*res://src/autoload/event_bus.gd"
GameState="*res://src/autoload/game_state.gd"
SimClock="*res://src/autoload/sim_clock.gd"
SaveManager="*res://src/autoload/save_manager.gd"
TypeRegistry="*res://src/autoload/type_registry.gd"
ConfigManager="*res://src/autoload/config_manager.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

[editor_plugins]

enabled=PackedStringArray("res://addons/gut/plugin.cfg")

[input]

sim_pause={
"deadzone": 0.5,
"events": [Object(InputEventKey,"physical_keycode":32)]
}
sim_speed_up={
"deadzone": 0.5,
"events": [Object(InputEventKey,"physical_keycode":93)]
}
sim_speed_down={
"deadzone": 0.5,
"events": [Object(InputEventKey,"physical_keycode":91)]
}
toggle_debug={
"deadzone": 0.5,
"events": [Object(InputEventKey,"physical_keycode":4194334)]
}

[rendering]

renderer/rendering_method="forward_plus"
